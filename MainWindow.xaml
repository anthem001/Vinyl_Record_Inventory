<Window x:Class="Record_Inventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Record_Inventory"
        mc:Ignorable="d"
        Title="Vinyl Sorter Dashboard" Height="650" Width="1050"
        Background="#121212">


    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Ready for Scan: " Foreground="#666666" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="BarcodeTextBox" Grid.Column="1" 
                     KeyDown="BarcodeTextBox_KeyDown"
                     Background="#1E1E1E" Foreground="White" BorderBrush="#333333" 
                     Padding="8,4" FontSize="14" CaretBrush="White"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6*"/>
                <ColumnDefinition Width="4*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,15,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0" Margin="0,0,0,15">
                    <TextBlock Text="{Binding CurrentArtist}" FontSize="28" FontWeight="Bold" Foreground="White"/>
                    <TextBlock Text="{Binding CurrentTitle}" FontSize="20" Foreground="#AAAAAA" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    <TextBlock Text="{Binding CurrentYear, StringFormat='Released: {0}'}" FontSize="14" Foreground="#666666"/>
                </StackPanel>

                <UniformGrid Grid.Row="1" Columns="3" Margin="0,0,0,15">
                    <Border Background="#1E1E1E" CornerRadius="6" Padding="10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="MEDIAN VALUE" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding CurrentPrice, StringFormat='${0:F2}'}" FontSize="22" FontWeight="Bold" Foreground="#4CAF50"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#1E1E1E" CornerRadius="6" Padding="10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="COMMUNITY RATING" FontSize="11" Foreground="#666666" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding RatingDisplayText}" FontSize="16" FontWeight="Bold" Foreground="#FFC107" TextWrapping="Wrap" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Background="#2D1A1A" CornerRadius="6" Padding="10">
                        <StackPanel>
                            <TextBlock Text="SUGGESTED ACTION" FontSize="11" Foreground="#996666" FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding SuggestedAction}" FontSize="18" FontWeight="Black" Foreground="#FF5252" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Grid.Row="2" 
                        Background="#1E1E1E" BorderBrush="#333333" BorderThickness="1" CornerRadius="8" 
                        MaxWidth="350" MaxHeight="350" HorizontalAlignment="Left" VerticalAlignment="Top">
                    <Grid>
                        <TextBlock Text="🎵" FontSize="48" Foreground="#333333" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        <Image Source="{Binding CurrentAlbumArt}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality" Margin="5"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" BorderBrush="#333333" BorderThickness="1" Padding="10">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Text="LOG" FontSize="12" FontWeight="Bold" Foreground="#666666" VerticalAlignment="Center"/>

                        <Button Grid.Column="1" Content="Export CSV" 
                                Click="ExportButton_Click"
                                Background="#4CAF50" Foreground="White" FontWeight="Bold" 
                                Padding="8,4" Margin="0,0,6,0" BorderThickness="0"/>

                        <Button Grid.Column="2" Content="Delete Active" 
                                Click="RemoveButton_Click"
                                Background="#D32F2F" Foreground="White" FontWeight="Bold" 
                                Padding="8,4" BorderThickness="0"/>
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{Binding ScannedHistory}" Background="Transparent" BorderThickness="0" SelectionChanged="LogList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="#2A2A2A" BorderThickness="0,0,0,1" Padding="0,6" Width="320">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="{Binding Title}" Foreground="White" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="{Binding Artist}" Foreground="#888888" FontSize="11"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{Binding Price, StringFormat='${0:F2}'}" Foreground="#4CAF50" FontWeight="Bold" VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

        </Grid>
    </Grid>
</Window>
