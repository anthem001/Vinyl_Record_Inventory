<Window x:Class="Record_Inventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Record_Inventory"
        mc:Ignorable="d"
        Title="Vinyl Sorter Dashboard" Height="700" Width="1250" Background="#121212">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#2D2D2D" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="READY FOR SCAN:" VerticalAlignment="Center" Foreground="#A0A0A0" FontWeight="Bold" FontSize="14" Margin="0,0,15,0"/>
                <TextBox Grid.Column="1" x:Name="BarcodeTextBox" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" FontSize="16" Padding="8,5" FontWeight="Medium" KeyDown="BarcodeTextBox_KeyDown"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4.5*"/>
                    <ColumnDefinition Width="5.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" BorderBrush="#2D2D2D" BorderThickness="1" Padding="12" Margin="0,0,15,0">
                    <Grid>
                        <Image Source="{Binding CurrentAlbumArt}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="No Cover Artwork Streamed" Foreground="#404040" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PlaceholderVisibility, FallbackValue=Visible}"/>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="15,20" BorderBrush="#2D2D2D" BorderThickness="1" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentArtist, FallbackValue='Scan an album to begin...'}" Foreground="#1DB954" FontSize="26" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                       </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1">
                        <UniformGrid Columns="2" Rows="3">
                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="RELEASE YEAR" FontSize="10" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentYear, FallbackValue='---'}" FontSize="18" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="COMMUNITY RATING" FontSize="10" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding RatingDisplayText, FallbackValue='---'}" FontSize="14" Foreground="#FFCC00" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ESTIMATED VALUE" FontSize="10" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentPrice, StringFormat={}{0:C}, FallbackValue='$0.00'}" FontSize="18" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="SUGGESTED ACTION" FontSize="10" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SuggestedAction, FallbackValue='AWAITING SCAN'}" FontSize="16" Foreground="#FF3333" FontWeight="Black" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5" Grid.ColumnSpan="1">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="GENRE" FontSize="10" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentGenre, FallbackValue='---'}" FontSize="13" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentGenre}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="STYLE" FontSize="10" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentStyle, FallbackValue='---'}" FontSize="13" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentStyle}"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SESSION LOG" Foreground="#A0A0A0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="Export CSV" Background="#1DB954" Foreground="White" FontWeight="Bold" Padding="8,4" Click="ExportButton_Click"/>
                    </Grid>
                    <ListView Grid.Row="1" x:Name="LogList" ItemsSource="{Binding ScannedHistory}" Background="Transparent" BorderThickness="0" Foreground="White" SelectionChanged="LogList_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="130"/>
                                <GridViewColumn Header="Artist" DisplayMemberBinding="{Binding Artist}" Width="110"/>
                                <GridViewColumn Header="Price" DisplayMemberBinding="{Binding Price, StringFormat={}{0:C}}" Width="60"/>
                                <GridViewColumn Header="Action" DisplayMemberBinding="{Binding Action}" Width="80"/>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Padding" Value="5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>