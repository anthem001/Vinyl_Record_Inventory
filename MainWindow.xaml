<Window x:Class="Record_Inventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Record_Inventory"
        mc:Ignorable="d"
        Title="Vinyl Sorter Dashboard" Height="850" Width="1200"
        Background="#121212">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#2D2D2D" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="READY FOR SCAN:" VerticalAlignment="Center" Foreground="#A0A0A0" FontWeight="Bold" FontSize="14" Margin="0,0,15,0"/>
                <TextBox Grid.Column="1" x:Name="BarcodeTextBox" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" FontSize="16" Padding="8,5" FontWeight="Medium" KeyDown="BarcodeTextBox_KeyDown"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="6.5*"/>
                <ColumnDefinition Width="3.5*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="20" BorderBrush="#2D2D2D" BorderThickness="1" Margin="0,0,0,15">
                    <StackPanel>
                        <TextBlock Text="{Binding CurrentArtist, FallbackValue='Scan an album to begin...'}" Foreground="#1DB954" FontSize="28" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                        <TextBlock Text="{Binding CurrentTitle, FallbackValue='---'}" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" Margin="0,5,0,15" TextTrimming="CharacterEllipsis"/>

                        <UniformGrid Columns="3" Rows="2" Margin="0,10,0,0">
                            <Border Background="#252525" CornerRadius="6" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="RELEASE YEAR" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentYear, FallbackValue='---'}" FontSize="18" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="COMMUNITY RATING" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding RatingDisplayText, FallbackValue='---'}" FontSize="14" Foreground="#FFCC00" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="ESTIMATED VALUE" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentPrice, StringFormat={}{0:C}, FallbackValue='$0.00'}" FontSize="18" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="GENRE" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentGenre, FallbackValue='---'}" FontSize="13" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentGenre}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="STYLE" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentStyle, FallbackValue='---'}" FontSize="13" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,4,0,0" TextTrimming="CharacterEllipsis" ToolTip="{Binding CurrentStyle}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="10" Margin="5">
                                <StackPanel>
                                    <TextBlock Text="SUGGESTED ACTION" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SuggestedAction, FallbackValue='AWAITING SCAN'}" FontSize="16" Foreground="#FF3333" FontWeight="Black" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" BorderBrush="#2D2D2D" BorderThickness="1" Padding="10">
                    <Grid>
                        <Image Source="{Binding CurrentAlbumArt}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="No Cover Artwork Streamed" Foreground="#404040" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PlaceholderVisibility, FallbackValue=Visible}"/>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SESSION LOG" Foreground="#A0A0A0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="1" Content="Remove Active" Background="#C62828" Foreground="White" FontWeight="Bold" Padding="10,5" Margin="0,0,5,0" Click="RemoveButton_Click"/>
                        <Button Grid.Column="2" Content="Export CSV" Background="#1DB954" Foreground="White" FontWeight="Bold" Padding="10,5" Click="ExportButton_Click"/>
                    </Grid>

                    <ListView Grid.Row="1" x:Name="LogList" ItemsSource="{Binding ScannedHistory}" Background="Transparent" BorderThickness="0" Foreground="White" SelectionChanged="LogList_SelectionChanged">
                        <ListView.View>
                            <GridView>
                                <GridViewColumn Header="Title" DisplayMemberBinding="{Binding Title}" Width="130"/>
                                <GridViewColumn Header="Artist" DisplayMemberBinding="{Binding Artist}" Width="110"/>
                                <GridViewColumn Header="Price" DisplayMemberBinding="{Binding Price, StringFormat={}{0:C}}" Width="60"/>
                                <GridViewColumn Header="Action" DisplayMemberBinding="{Binding Action}" Width="80"/>
                            </GridView>
                        </ListView.View>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="Margin" Value="0,2"/>
                                <Setter Property="Padding" Value="5"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#2A2A2A"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
