<Window x:Class="Record_Inventory.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Record_Inventory"
        mc:Ignorable="d"
        Title="Vinyl Sorter Dashboard" Height="700" Width="1250" Background="#121212">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="15" Margin="0,0,0,15" BorderBrush="#2D2D2D" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="READY FOR SCAN:" VerticalAlignment="Center" Foreground="#A0A0A0" FontWeight="Bold" FontSize="14" Margin="0,0,15,0"/>
                <TextBox Grid.Column="1" x:Name="BarcodeTextBox" Background="#2D2D2D" Foreground="#FFFFFF" BorderBrush="#404040" FontSize="16" Padding="8,5" FontWeight="Medium" KeyDown="BarcodeTextBox_KeyDown"/>
                <Button Grid.Column="2" x:Name="BtnManualSearch" Content="No Barcode/Manual Search" Click="BtnManualSearch_Click" Height="35" VerticalAlignment="Center" Margin="10,0,0,0" Background="#1DB954" Foreground="White" FontWeight="SemiBold" BorderThickness="1" BorderBrush="#444444" Padding="10,0"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="7*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,10,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="4.5*"/>
                    <ColumnDefinition Width="5.5*"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="#1E1E1E" CornerRadius="8" BorderBrush="#2D2D2D" BorderThickness="1" Padding="12" Margin="0,0,15,0">
                    <Grid>
                        <Image Source="{Binding CurrentAlbumArt}" Stretch="Uniform" RenderOptions.BitmapScalingMode="HighQuality"/>
                        <TextBlock Text="No Cover Artwork Streamed" Foreground="#404040" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="{Binding PlaceholderVisibility, FallbackValue=Visible}"/>
                    </Grid>
                </Border>

                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E1E1E" CornerRadius="8" Padding="15,20" BorderBrush="#2D2D2D" BorderThickness="1" Margin="0,0,0,15">
                        <StackPanel>
                            <TextBlock Text="{Binding CurrentArtist, FallbackValue='Scan an album to begin...'}" Foreground="#1DB954" FontSize="28" FontWeight="Black" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CurrentTitle, FallbackValue='---'}" Foreground="#FFFFFF" FontSize="20" FontWeight="Bold" Margin="0,6,0,0" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1">
                        <UniformGrid Columns="2" Rows="3">

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="RELEASE YEAR" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentYear, FallbackValue='---'}" FontSize="22" Foreground="#FFFFFF" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="COMMUNITY RATING" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding RatingDisplayText, FallbackValue='---'}" FontSize="18" Foreground="#FFCC00" FontWeight="Bold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="ESTIMATED VALUE" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentPrice, StringFormat={}{0:C}, FallbackValue='$0.00'}" FontSize="22" Foreground="#4CAF50" FontWeight="Bold" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="SUGGESTED ACTION" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding SuggestedAction, FallbackValue='AWAITING SCAN'}" FontSize="20" Foreground="#FF3333" FontWeight="Black" Margin="0,4,0,0"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="GENRE" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentGenre, FallbackValue='---'}" FontSize="15" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" ToolTip="{Binding CurrentGenre}"/>
                                </StackPanel>
                            </Border>

                            <Border Background="#252525" CornerRadius="6" Padding="12" Margin="5">
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="STYLE" FontSize="11" Foreground="#808080" FontWeight="Bold"/>
                                    <TextBlock Text="{Binding CurrentStyle, FallbackValue='---'}" FontSize="15" Foreground="#E0E0E0" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap" ToolTip="{Binding CurrentStyle}"/>
                                </StackPanel>
                            </Border>

                        </UniformGrid>
                    </Border>
                </Grid>
            </Grid>

            <Border Grid.Column="1" Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1" Margin="10,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="SESSION LOG" Foreground="#A0A0A0" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                        <Button Grid.Column="2" Content="Export CSV" Background="#1DB954" Foreground="White" FontWeight="Bold" Padding="8,4" Click="ExportButton_Click"/>
                    </Grid>

                    <ListView Grid.Row="1" x:Name="LogList" ItemsSource="{Binding ScannedHistory}" Background="Transparent" BorderThickness="0" Foreground="White" SelectionChanged="LogList_SelectionChanged" HorizontalContentAlignment="Stretch" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,2" HorizontalAlignment="Stretch">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,10,0">
                                        <TextBlock Text="{Binding Title}" Foreground="#FFFFFF" FontSize="14" FontWeight="Bold" TextTrimming="CharacterEllipsis" Margin="0,0,0,2"/>
                                        <TextBlock Text="{Binding Artist}" Foreground="#8A8A8A" FontSize="12" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>

                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="#202020"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                                <Setter Property="Padding" Value="6,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#1A1A1A"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="Background" Value="#252525"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </ListView.ItemContainerStyle>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>